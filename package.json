{
  "name": "hermetika",
  "private": true,
  "type": "module",
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "dev": "bun run dev:server & bun run dev:web",
    "dev:server": "cd apps/server && bun --watch src/index.ts",
    "dev:web": "bun run --filter './apps/web' dev",
    "test": "bun test",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "devDependencies": {
    "bun-types": "^1.3.14"
  }
}
