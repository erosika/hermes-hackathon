# gateway
PORT=3001

# ── auth (real) — verify the Supabase-issued JWT on the gateway ──
# Supabase Dashboard → Project Settings → API → "JWT Secret". required for real auth.
SUPABASE_JWT_SECRET=

# ── billing — one plan, redirect the subscribe button to a Stripe surface ──
PANTHEON_PRICE_USD=2
# a Stripe Payment Link (subscribe) or Billing Portal url. unset = local demo checkout.
STRIPE_PORTAL_URL=
# webhook signature verification (unset = demo mode parses the body directly)
STRIPE_WEBHOOK_SECRET=
STRIPE_SECRET_KEY=

# seed a couple demo subscribers at boot so MRR isn't empty (0 = off). default on.
SEED_DEMO_REVENUE=

# ── inference backends ──
# proxy providers (non-self-hosted pantheon models)
NVIDIA_API_KEY=
NOUS_API_KEY=
OPENROUTER_API_KEY=
# self-host GPU — DGX Spark over Tailscale. hot lane (vLLM) + breadth lane (Ollama)
SPARK_VLLM_URL=
SPARK_OLLAMA_URL=
BREV_BASE_URL=
BREV_API_KEY=

# honcho — sessions + operator memory
HONCHO_API_KEY=
HONCHO_WORKSPACE=hermetika

# supabase — persistence (registry/subscriptions/usage) system-of-record
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
