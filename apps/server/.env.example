# gateway
PORT=3001

# ── auth (real) — gateway verifies the Supabase token via GET /auth/v1/user ──
# both from Dashboard → Project Settings → API (or `supabase projects api-keys`). not secret.
SUPABASE_URL=
SUPABASE_ANON_KEY=

# ── billing — Pantheon Pro, real Stripe Checkout ──
PANTHEON_PRICE_USD=2
# real mode: server creates a Checkout Session (subscription) with this secret key (sk_test_…)
STRIPE_SECRET_KEY=
# webhook signing secret from `stripe listen` (whsec_…); unset = demo mode parses the body
STRIPE_WEBHOOK_SECRET=
# where Checkout returns to after pay/cancel
APP_URL=http://localhost:5173
# optional alt: a static Stripe Payment Link / Billing Portal url (used if no secret key)
STRIPE_PORTAL_URL=

# seed a couple demo subscribers at boot so MRR isn't empty (0 = off). default on.
SEED_DEMO_REVENUE=

# ── inference backends ──
# proxy providers (non-self-hosted pantheon models)
NVIDIA_API_KEY=
NOUS_API_KEY=
OPENROUTER_API_KEY=
# self-host GPU — DGX Spark over Tailscale. hot lane (vLLM) + breadth lane (Ollama)
SPARK_VLLM_URL=
SPARK_OLLAMA_URL=
BREV_BASE_URL=
BREV_API_KEY=

# honcho — sessions + operator memory
HONCHO_API_KEY=
HONCHO_WORKSPACE=hermetika

# supabase — persistence (registry/subscriptions/usage), uses SUPABASE_URL above
SUPABASE_SERVICE_KEY=
