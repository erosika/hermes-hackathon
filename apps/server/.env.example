# gateway
PORT=3001

# proxy providers (the pantheon's non-self-hosted models)
NVIDIA_API_KEY=
NOUS_API_KEY=
OPENROUTER_API_KEY=

# self-host GPU — DGX Spark, two lanes over Tailscale
# hot lane: vLLM, 1-3B lightning models (e.g. http://spark.tail-scale.ts.net:8000/v1)
SPARK_VLLM_URL=
# breadth lane: Ollama, the paged long tail (e.g. http://spark.tail-scale.ts.net:11434/v1)
SPARK_OLLAMA_URL=
# Brev = paid burst (the survival-loop spend side)
BREV_BASE_URL=
BREV_API_KEY=
MODAL_BASE_URL=
MODAL_API_KEY=

# honcho — sessions + operator memory
HONCHO_API_KEY=
HONCHO_WORKSPACE=hermetika

# stripe — subs + skills survival loop
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# steward spend actuator — which rail buys compute.
# demo (book only) | stripe (Stripe Issuing agent wallet, fiat — recommended) | link
STEWARD_RAIL=demo
# guard: hard ceilings enforced server-side before any rail spends (mirrored onto the card too).
STEWARD_MAX_TX_USD=50
STEWARD_MAX_DAILY_USD=200
STEWARD_HALT=            # 1 = kill-switch, halts all autonomous spend

# rail: stripe — Stripe Issuing for agents. one spend-controlled virtual card, no crypto.
STEWARD_ISSUING_ARMED=            # 1 = hit real Stripe; unset = dry-run (no API call)
STRIPE_ISSUING_CARD=             # the agent's card id (provision once via provisionAgentCard)
STEWARD_ISSUING_CATEGORIES=      # comma-sep allowed merchant categories (empty = unrestricted)

# rail: link (bundled skill payments/stripe-link-cli). confirm surface via `link-cli --llms-full`.
# e.g. STEWARD_LINK_CMD="link-cli mpp pay --amount {amount} --to brev"
STEWARD_LINK_CMD=

# seed demo customer revenue at boot so the P&L has a revenue side (0 = off). default on.
SEED_DEMO_REVENUE=

# supabase — registry + ledger
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
